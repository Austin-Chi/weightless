{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake -S . -B build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake --build build -j",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "CMake: Configure",
      "dependsOrder": "sequence",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "CMake: Run",
      "type": "shell",
      "command": "./build/Metal_Engine_cpp",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: Build",
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "CMake: Clean",
      "type": "shell",
      "command": "rm -rf build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Rebuild",
      "type": "shell",
      "command": "echo Rebuild complete",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "CMake: Clean",
        "CMake: Build"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
